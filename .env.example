# Canonical public URL (no trailing slash).
# On Vercel: set this in Project → Settings → Environment Variables
# for Production (and Preview if you use a fixed preview domain).
#
# Examples:
#   Production custom domain:  https://lkautocare.com
#   Vercel default:            https://lk-auto-care.vercel.app
#
# If unset, the app falls back to Vercel system vars (VERCEL_URL /
# VERCEL_PROJECT_PRODUCTION_URL), then https://lkautocare.com.
NEXT_PUBLIC_SITE_URL=https://lkautocare.com

# Web3Forms access key (FREE — contact form emails the shop owner).
# 1. Create a key at https://web3forms.com (use the business inbox, e.g. hello@lkautocare.com)
# 2. Confirm the email they send you
# 3. Paste the access key here and on Vercel → Environment Variables
# Free plan: 250 submissions / month — no card required.
WEB3FORMS_ACCESS_KEY=
