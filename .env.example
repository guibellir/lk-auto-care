# Canonical public URL (no trailing slash).
# On Vercel: set this in Project → Settings → Environment Variables
# for Production (and Preview if you use a fixed preview domain).
#
# Examples:
#   Production custom domain:  https://lkautocare.net
#   Vercel default:            https://lk-auto-care.vercel.app
#
# If unset, the app falls back to Vercel system vars (VERCEL_URL /
# VERCEL_PROJECT_PRODUCTION_URL), then https://lkautocare.net.
NEXT_PUBLIC_SITE_URL=https://lkautocare.net

# Web3Forms access key (FREE — contact form emails the shop owner).
# Free plan only works from the browser, so the key must be NEXT_PUBLIC_*.
# 1. Create a key at https://web3forms.com (email = inbox that receives leads)
# 2. Confirm that email
# 3. Paste below (also already in committed `.env` for this project)
# Free plan: 250 submissions / month — no card required.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
